{
  "name": "nuxt-i18n-widget",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --disable-warning=DEP0155\" nuxt build",
    "dev": "nuxt dev",
    "generate": "cross-env NODE_OPTIONS=\"--max-old-space-size=8192 --disable-warning=DEP0155\" nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "sync-data": "node scripts/sync-spoke-data.mjs",
    "i18n:split": "node scripts/i18n/split-locales.mjs",
    "i18n:fill-missing": "node scripts/i18n/fill-missing.mjs",
    "i18n:build": "node scripts/i18n/build-locales.mjs",
    "i18n:check": "node scripts/i18n/check-messages.mjs",
    "check:html-cache": "node scripts/storefront/check-html-cache-build.mjs",
    "smoke:html-cache": "node scripts/storefront/smoke-html-cache-preview.mjs",
    "check-locales": "node scripts/check-locales.mjs",
    "clean": "node -e \"require('fs').rmSync('.nuxt', { recursive: true, force: true }); require('fs').rmSync('node_modules/.cache', { recursive: true, force: true });\""
  },
  "dependencies": {
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/icon": "^2.2.4",
    "@nuxt/image": "^2.0.0",
    "@nuxtjs/i18n": "^9.1.0",
    "@nuxtjs/sitemap": "^7.5.0",
    "@pinia/nuxt": "^0.11.3",
    "@vueuse/core": "^14.0.0",
    "@vueuse/integrations": "^14.3.0",
    "focus-trap": "^8.2.2",
    "ioredis": "^5.11.1",
    "nuxt": "^4.1.3",
    "pinia": "^3.0.4",
    "unstorage": "^1.17.5",
    "vue": "^3.5.22",
    "vue-router": "^4.6.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "autoprefixer": "^10.4.22",
    "cross-env": "^10.1.0",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "ttf2woff": "^3.0.0",
    "ttf2woff2": "^8.0.0"
  }
}
