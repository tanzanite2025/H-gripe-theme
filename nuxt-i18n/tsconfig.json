{
  // https://nuxt.com/docs/guide/concepts/typescript
  "compilerOptions": {
    "baseUrl": ".",
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "paths": {
      "~/*": ["./app/*"],
      "@/*": ["./app/*"],
      "~/components/*": ["./app/components/*"],
      "~/composables/*": ["./app/composables/*"],
      "~/utils/*": ["./app/utils/*"],
      "~/types/*": ["types/*"],
      "@/types/*": ["types/*"],
      "#imports": ["./.nuxt/imports.d.ts"]
    },
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "typeRoots": [
      "./.nuxt/types",
      "./types",
      "./node_modules/@types"
    ]
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.vue",
    "types/**/*.d.ts",
    ".nuxt/**/*.d.ts"
  ]
}
