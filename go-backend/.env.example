# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_secure_password_here
DB_NAME=tanzanite
DB_SSLMODE=disable

# JWT Secret
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRATION=24h

# Server Configuration
SERVER_PORT=:8080
SERVER_MODE=debug
SERVER_HOST=localhost

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# CORS Origins (comma separated)
CORS_ORIGINS=https://tanzanite.site,http://localhost:3000

# Email Configuration (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=noreply@tanzanite.com
SMTP_FROM_NAME=Tanzanite

# File Storage Configuration
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./uploads
STORAGE_BASE_URL=http://localhost:8080
# For S3/OSS
STORAGE_BUCKET=
STORAGE_REGION=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_ENDPOINT=

# Payment Gateway Configuration
# Stripe
STRIPE_API_KEY=sk_test_your_stripe_secret_key
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_ENVIRONMENT=sandbox

# PayPal
PAYPAL_API_KEY=your_paypal_client_id
PAYPAL_SECRET_KEY=your_paypal_secret
PAYPAL_WEBHOOK_SECRET=your_webhook_id
PAYPAL_ENVIRONMENT=sandbox

# Alipay
ALIPAY_API_KEY=your_alipay_app_id
ALIPAY_SECRET_KEY=your_alipay_private_key
ALIPAY_WEBHOOK_SECRET=your_alipay_public_key
ALIPAY_ENVIRONMENT=sandbox

# WeChat Pay
WECHAT_API_KEY=your_wechat_mch_id
WECHAT_SECRET_KEY=your_wechat_api_key
WECHAT_WEBHOOK_SECRET=your_wechat_api_v3_key
WECHAT_ENVIRONMENT=sandbox

# Tracking Service Configuration (17TRACK)
TRACKING_PROVIDER=17track
TRACKING_API_KEY=your_17track_api_key
TRACKING_BASE_URL=https://api.17track.net/track/v2

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_DURATION=1m

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# i18n
DEFAULT_LANGUAGE=en
SUPPORTED_LANGUAGES=en,zh,es,fr,de,ja,ko,ar,pt,ru,it,nl,pl,tr,vi,th,id,ms,hi,bn,ur,fa,he,sv,no,da,fi,cs,hu,ro,uk,el,bg,sr,hr,sk,sl
